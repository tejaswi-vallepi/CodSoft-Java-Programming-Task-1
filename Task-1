import random

# Number Guessing Game - CodSoft Internship Task

def play_game():
    MAX_ATTEMPTS = 10
    score = 0
    round_number = 1

    print("=" * 50)
    print("        WELCOME TO NUMBER GUESSING GAME")
    print("=" * 50)

    while True:
        print(f"\nRound {round_number}")
        print("-" * 20)

        secret_number = random.randint(1, 100)
        attempts_left = MAX_ATTEMPTS
        guessed_correctly = False

        print("I have selected a number between 1 and 100.")
        print(f"You have {MAX_ATTEMPTS} attempts to guess it.")

        while attempts_left > 0:
            try:
                guess = int(input("\nEnter your guess: "))

                if guess < 1 or guess > 100:
                    print("Please enter a number between 1 and 100.")
                    continue

                attempts_left -= 1

                if guess == secret_number:
                    print("\n🎉 Congratulations! You guessed the number correctly!")
                    print(f"Number: {secret_number}")

                    # Score based on remaining attempts
                    round_score = attempts_left + 1
                    score += round_score

                    print(f"Round Score: {round_score}")
                    guessed_correctly = True
                    break

                elif guess < secret_number:
                    print("📉 Too Low! Try again.")
                else:
                    print("📈 Too High! Try again.")

                print(f"Attempts Left: {attempts_left}")

            except ValueError:
                print("Invalid input! Please enter a valid number.")

        if not guessed_correctly:
            print("\n❌ Game Over!")
            print(f"The correct number was: {secret_number}")

        print("\n" + "=" * 40)
        print(f"Total Score: {score}")
        print("=" * 40)

        play_again = input("\nDo you want to play another round? (yes/no): ").lower()

        if play_again not in ["yes", "y"]:
            print("\nThank you for playing!")
            print(f"Final Score: {score}")
            print("Goodbye!")
            break

        round_number += 1


# Start the game
play_game()
